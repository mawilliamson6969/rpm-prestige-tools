# Copy this file to `.env` on the server (and locally if you run compose here).
# docker-compose.yml requires POSTGRES_PASSWORD at runtime.

POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Optional: when running `next dev` locally, point at Express (no /api prefix — paths are /dashboard/…, /appfolio/…).
# Leave unset in production if the browser uses the same host and Nginx maps /api/* to this API.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# AppFolio Property Manager API (HTTP Basic: Client ID / Client Secret)
# https://[subdomain].appfolio.com/api/v1/
APPFOLIO_CLIENT_ID=
APPFOLIO_CLIENT_SECRET=
APPFOLIO_SUBDOMAIN=
