# Copy this file to `.env` on the server (and locally if you run compose here).
# docker-compose.yml requires POSTGRES_PASSWORD at runtime.

POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Optional: when running `next dev` locally, point at Express (no /api prefix — paths are /dashboard/…, /appfolio/…, /forms/…).
# Leave unset in production if the browser uses the same host and Nginx maps /api/* to this API.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# AppFolio Property Manager — Reports API v2 (HTTP Basic: Client ID / Client Secret)
# https://[subdomain].appfolio.com/api/v2/reports/…
APPFOLIO_CLIENT_ID=
APPFOLIO_CLIENT_SECRET=
APPFOLIO_SUBDOMAIN=

# AppFolio Property Manager — Database API v0 (HTTP Basic + X-AppFolio-Developer-ID)
# Used by backend/services/appfolio-db-api.js (client) and
# backend/services/appfolio-db-sync.js (af_* mirror backfill).
# Distinct credentials from the Reports API above. NEVER commit real
# credentials — use a secrets vault on the server.
APPFOLIO_DB_CLIENT_ID=
APPFOLIO_DB_CLIENT_SECRET=
APPFOLIO_DB_DEVELOPER_ID=
# Optional base-URL override. Defaults to production when unset. Must be
# https on a *.appfolio.com host (the client refuses anything else).
# Sandbox (practice database): https://practicerpmtx033.appfolio.com/api/v0
APPFOLIO_DB_BASE_URL=https://api.appfolio.com/api/v0
# Write gate. When 'true': GETs run normally, but POST/PATCH/DELETE are NOT
# sent — the skipped write is logged (method, path, payload summary; never
# values/secrets) and { dryRun: true } is returned. Defaults to false.
# Recommended 'true' anywhere write features are under test.
APPFOLIO_DB_DRY_RUN=false
# Optional: when 'true', services/appfolio-db-api.js prints one debug line
# per outbound request (method, path, status, latency). Never logs request/
# response bodies or secrets. Leave false/unset in production.
APPFOLIO_DB_DEBUG=false
# Scheduled mirror sync (services/appfolio-db-scheduler.js). Enabled by
# default; auto-disables with a log line when the DB-API creds above are
# absent, so local dev never errors. Cron overrides run in America/Chicago.
APPFOLIO_SYNC_ENABLED=true
APPFOLIO_SYNC_DELTA_CRON=0 * * * *
APPFOLIO_SYNC_FULL_CRON=0 3 * * *

# Owner termination form — team notifications & integrations
TEAM_NOTIFICATION_EMAILS=
TEAMS_WEBHOOK_URL=
LEADSIMPLE_API_KEY=

# SMTP (nodemailer) for team emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Team login (JWT signing). Required for POST /auth/login and protected API routes. Generate a long random string.
JWT_SECRET=476aea299d1d5f1332ce76fcebf644dacf9af446896162122217f40cc969490b

# Ask the AI (Claude) — internal SQL assistant over cached AppFolio data. Required for POST /ask.
ANTHROPIC_API_KEY=

# OpenAI — Whisper transcription for async video library (`/videos` uploads). Optional; if unset, transcript is marked unavailable.
OPENAI_API_KEY=

# Microsoft Graph — Shared Inbox OAuth (Azure app registration)
MICROSOFT_CLIENT_ID=f999e00e-e4ba-42b0-b6f6-5caeed9efea0
MICROSOFT_TENANT_ID=be5ea140-6f5e-4056-947a-86fcf83d025d
MICROSOFT_CLIENT_SECRET=
# Registered redirect URI (Nginx serves /api/* → Express paths without /api)
MICROSOFT_REDIRECT_URI=https://dashboard.prestigedash.com/api/auth/microsoft/callback

# OAuth success redirect and inbox links (no trailing slash)
FRONTEND_URL=https://dashboard.prestigedash.com

# RentEngine — public API (Bearer). Used by dashboard sync for prospects + units.
RENTENGINE_API_KEY=

# BoomScreen — Partner API (Bearer from POST /authenticate). Screening applications + property/unit registry.
BOOM_ACCESS_KEY=
BOOM_SECRET_KEY=

# LetterStream — physical mail delivery API (get credentials from letterstream.com → API Information)
LETTERSTREAM_API_ID=
LETTERSTREAM_API_KEY=
LETTERSTREAM_BASE_URL=https://www.letterstream.com/apis/
# When 'true', LetterStream returns -105 instead of -100 and does NOT actually mail.
# Flip to 'false' only when ready to send real mail.
LETTERSTREAM_TEST_MODE=true
# Shared secret configured in LetterStream → API Callback Settings. Used to verify webhook POSTs.
LETTERSTREAM_WEBHOOK_KEY=

# Docuseal (self-hosted e-sign at sign.prestigedash.com)
# DOCUSEAL_API_URL is the internal compose-network URL the backend uses; leave default unless changing the service name.
# DOCUSEAL_API_KEY is generated in the Docuseal admin UI after first login.
DOCUSEAL_API_URL=http://docuseal:3000/api
DOCUSEAL_API_KEY=

# Prestige Connect — automation event bus + worker.
# OpenPhone: API key powers SMS send + inbound webhook signature verification.
OPENPHONE_API_KEY=
OPENPHONE_FROM_NUMBER=
# Shared secret you set in OpenPhone's webhook config. Required in production
# (the receiver fails closed when NODE_ENV=production and this is empty).
OPENPHONE_WEBHOOK_SECRET=
# Microsoft Graph change-notification shared secret (clientState). Echoed
# back to us with every notification — receiver drops any that don't match.
MS_GRAPH_CLIENT_STATE=
