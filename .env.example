# Copy this file to `.env` on the server (and locally if you run compose here).
# docker-compose.yml requires POSTGRES_PASSWORD at runtime.

POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Optional: when running `next dev` locally, point at Express (no /api prefix — paths are /dashboard/…, /appfolio/…, /forms/…).
# Leave unset in production if the browser uses the same host and Nginx maps /api/* to this API.
# NEXT_PUBLIC_API_URL=http://127.0.0.1:4000

# AppFolio Property Manager — Reports API v2 (HTTP Basic: Client ID / Client Secret)
# https://[subdomain].appfolio.com/api/v2/reports/…
APPFOLIO_CLIENT_ID=
APPFOLIO_CLIENT_SECRET=
APPFOLIO_SUBDOMAIN=

# Owner termination form — team notifications & integrations
TEAM_NOTIFICATION_EMAILS=
TEAMS_WEBHOOK_URL=
LEADSIMPLE_API_KEY=

# SMTP (nodemailer) for team emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Team login (JWT signing). Required for POST /auth/login and protected API routes. Generate a long random string.
JWT_SECRET=476aea299d1d5f1332ce76fcebf644dacf9af446896162122217f40cc969490b

# Ask the AI (Claude) — internal SQL assistant over cached AppFolio data. Required for POST /ask.
ANTHROPIC_API_KEY=

# OpenAI — Whisper transcription for async video library (`/videos` uploads). Optional; if unset, transcript is marked unavailable.
OPENAI_API_KEY=

# Microsoft Graph — Shared Inbox OAuth (Azure app registration)
MICROSOFT_CLIENT_ID=f999e00e-e4ba-42b0-b6f6-5caeed9efea0
MICROSOFT_TENANT_ID=be5ea140-6f5e-4056-947a-86fcf83d025d
MICROSOFT_CLIENT_SECRET=
# Registered redirect URI (Nginx serves /api/* → Express paths without /api)
MICROSOFT_REDIRECT_URI=https://dashboard.prestigedash.com/api/auth/microsoft/callback

# OAuth success redirect and inbox links (no trailing slash)
FRONTEND_URL=https://dashboard.prestigedash.com

# RentEngine — public API (Bearer). Used by dashboard sync for prospects + units.
RENTENGINE_API_KEY=

# BoomScreen — Partner API (Bearer from POST /authenticate). Screening applications + property/unit registry.
BOOM_ACCESS_KEY=
BOOM_SECRET_KEY=
